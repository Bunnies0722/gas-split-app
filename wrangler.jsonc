{
  "name": "gas-split-app",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./prototype",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "triggers": {
    "crons": ["0 6 * * 3"]
  }
}
